# lumi.yaml — copy to lumi.yaml and set your API key

# OpenAI-compatible DeepSeek (local tools only)
llm:
  provider: deepseek
  base_url: https://api.deepseek.com/v1
  api_key: ${DEEPSEEK_API_KEY}
  model: deepseek-v4-pro
  temperature: 0.7
  max_tokens: 4096
  timeout: 60

# For web search, use deepseek-anthropic instead:
# llm:
#   provider: deepseek-anthropic
#   api_key: ${DEEPSEEK_API_KEY}
#   model: deepseek-v4-pro
#   timeout: 120
# tools:
#   server:
#     enabled: [WebSearch]

agent:
  max_steps: 20
  system_prompt: default
  context_window: 20

tools:
  workspace: .
  enabled:
    - Read
    - Write
    - Bash
  bash:
    timeout: 30
    allowed_commands: []
  server:
    enabled: []
    web_search:
      type: web_search_20260209
      max_uses: 5

logging:
  level: INFO
  format: text
