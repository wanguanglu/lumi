# lumi.yaml — copy to lumi.yaml and set your API key

llm:
  provider: deepseek                    # openai | deepseek | ollama
  base_url: https://api.deepseek.com/v1 # optional for known providers
  api_key: ${DEEPSEEK_API_KEY}
  model: deepseek-chat
  temperature: 0.7
  max_tokens: 4096
  timeout: 60

agent:
  max_steps: 20
  system_prompt: default
  context_window: 20

tools:
  enabled:
    - read_file
    - write_file
    - run_shell
  shell:
    timeout: 30
    allowed_commands: []   # empty = allow all (dev mode)

logging:
  level: INFO
  format: text
