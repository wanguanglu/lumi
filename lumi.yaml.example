# lumi.yaml — copy to lumi.yaml and set your API key

llm:
  provider: openai
  base_url: https://api.openai.com/v1
  api_key: ${OPENAI_API_KEY}
  model: gpt-4o
  temperature: 0.7
  max_tokens: 4096
  timeout: 60

agent:
  max_steps: 20
  system_prompt: default
  context_window: 20

tools:
  enabled:
    - read_file
    - write_file
    - run_shell
  shell:
    timeout: 30
    allowed_commands: []   # empty = allow all (dev mode)

logging:
  level: INFO
  format: text
